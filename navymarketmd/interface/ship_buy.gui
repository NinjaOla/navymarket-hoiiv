		containerWindowType = {
			name = "buy_available_section"
			position = { x = 20 y = 620 }
			size = { width = 410 height = 30 }

			instantTextBoxType = {
				name = "buy_available_label"
				position = { x = 0 y = 5 }
				font = "hoi_18mbs"
				text = "SHIP_MARKET_AVAILABLE"
				maxWidth = 200
				maxHeight = 25
				format = left
			}
			instantTextBoxType = {
				name = "buy_available_count"
				position = { x = 200 y = 5 }
				font = "hoi_18mbs"
				text = "[?buy_max_available|0]"
				maxWidth = 60
				maxHeight = 25
				format = left
			}
		}

		### Action buttons
		buttonType = {
			name = "buy_confirm_button"
			position = { x = 20 y = 675 }
			quadTextureSprite = "GFX_button_123x34"
			buttonFont = "hoi_16mbs"
			buttonText = "SHIP_BUY_CONFIRM"
			clicksound = click_default
		}

		buttonType = {
			name = "buy_back_button"
			position = { x = 160 y = 675 }
			quadTextureSprite = "GFX_button_123x34"
			buttonFont = "hoi_16mbs"
			buttonText = "SHIP_BUY_BACK"
			clicksound = click_default
		}

		buttonType = {
			name = "buy_cancel_button"
			position = { x = 300 y = 675 }
			quadTextureSprite = "GFX_button_123x34"
			buttonFont = "hoi_16mbs"
			buttonText = "SHIP_BUY_CANCEL"
			clicksound = click_close
		}
	}

	### Entry template for seller dynamic list (one per seller in seller_list array)
	### change_scope = yes means scope = seller country
	containerWindowType = {
		name = "seller_entry"
		size = { width = 400 height = 35 }

		buttonType = {
			name = "seller_entry_button"
			position = { x = 0 y = 0 }
			spriteType = "GFX_tiling_sort_button"
			frame = 1
			size = { x = 400 y = 30 }
			clicksound = click_checkbox
			buttonText = "[Country.GetName]"
			buttonFont = "hoi_18mbs"
		}
	}

	### Entry template for selected seller name display (1 element)
	containerWindowType = {
		name = "seller_name_entry"
		size = { width = 260 height = 30 }

		instantTextBoxType = {
			name = "seller_name_text"
			position = { x = 0 y = 5 }
			font = "hoi_18mbs"
			text = "[Country.GetName]"
			maxWidth = 250
			maxHeight = 25
		}
	}
}
