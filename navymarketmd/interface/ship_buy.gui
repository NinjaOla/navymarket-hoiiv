guiTypes = {

	### ===================== PHASE 1: Seller List =====================
	containerWindowType = {
		name = "ship_buy_sellers_window"
		position = { x = -225 y = -280 }
		size = { width = 450 height = 560 }
		orientation = center
		moveable = yes

		background = {
			name = "Background"
			spriteType = "GFX_tiled_window_1b_border"
		}

		# Close button
		buttonType = {
			name = "buy_close_button"
			position = { x = -45 y = 12 }
			quadTextureSprite = "GFX_closebutton"
			orientation = "UPPER_RIGHT"
			clicksound = click_close
			shortcut = "ESCAPE"
		}

		# Title
		instantTextBoxType = {
			name = "sellers_title"
			position = { x = 50 y = 15 }
			font = "hoi_36header"
			text = "SHIP_BUY_TITLE_SELLERS"
			maxWidth = 350
			maxHeight = 40
			format = centre
		}

		# Instructions
		instantTextBoxType = {
			name = "sellers_instructions"
			position = { x = 20 y = 55 }
			font = "hoi_18mbs"
			text = "SHIP_BUY_SELLER_LABEL"
			maxWidth = 410
			maxHeight = 30
			format = centre
		}

		# No sellers message
		instantTextBoxType = {
			name = "no_sellers_text"
			position = { x = 20 y = 150 }
			font = "hoi_18mbs"
			text = "SHIP_BUY_NO_SELLERS"
			maxWidth = 410
			maxHeight = 30
			format = centre
		}

		# Scrollable seller list via dynamic_lists gridbox
		containerWindowType = {
			name = "seller_grid_container"
			position = { x = 20 y = 90 }
			size = { width = 415 height = 380 }
			verticalScrollbar = "right_vertical_slider"
			scroll_wheel_factor = 40
			smooth_scrolling = yes

			background = {
				name = "Background"
				quadTextureSprite = "GFX_tiled_window_transparent"
			}

			gridBoxType = {
				name = "seller_grid_box"
				position = { x = 0 y = 0 }
				size = { width = 100%% height = 100%% }
				slotsize = { width = 400 height = 35 }
				format = "UPPER_LEFT"
				max_slots_horizontal = 1
			}
		}

		# Cancel button (phase 1)
		buttonType = {
			name = "buy_cancel_p1_button"
			position = { x = 160 y = 500 }
			quadTextureSprite = "GFX_button_123x34"
			buttonFont = "hoi_16mbs"
			buttonText = "SHIP_BUY_CANCEL"
			clicksound = click_close
		}
	}

